-- // SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local function getCharacter()
	local char = player.Character or player.CharacterAdded:Wait()
	local hrp = char:WaitForChild("HumanoidRootPart")
	local hum = char:WaitForChild("Humanoid")
	return char, hrp, hum
end

local char, hrp, hum = getCharacter()

player.CharacterAdded:Connect(function()
	char, hrp, hum = getCharacter()
end)

-- // SETTINGS
local spinSpeed = 2          -- rotatiesnelheid
local flySpeed = 1         -- snelheid voor rustiger vliegen (0.5 studs per seconde omhoog)

-- // STATES
local spinning = false
local flying = false
local flyBody -- BodyVelocity voor fly

-- // GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FlySpinGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local spinButton = Instance.new("TextButton")
spinButton.Size = UDim2.new(0, 150, 0, 40)
spinButton.Position = UDim2.new(0, 20, 0, 200)
spinButton.Text = "Spin"
spinButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)  -- Blauw
spinButton.TextColor3 = Color3.fromRGB(255, 255, 255)     -- Wit
spinButton.Parent = screenGui

local flyButton = Instance.new("TextButton")
flyButton.Size = UDim2.new(0, 150, 0, 40)
flyButton.Position = UDim2.new(0, 20, 0, 250)
flyButton.Text = "Fly"
flyButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)  -- Blauw
flyButton.TextColor3 = Color3.fromRGB(255, 255, 255)     -- Wit
flyButton.Parent = screenGui

-- // BUTTON LOGIC
spinButton.MouseButton1Click:Connect(function()
	spinning = not spinning
	spinButton.Text = spinning and "Stop Spinning" or "Spin"
end)

flyButton.MouseButton1Click:Connect(function()
	flying = not flying
	flyButton.Text = flying and "Stop Flying" or "Fly"

	if flying then
		-- Zet PlatformStand aan voor rustiger vliegen
		hum.PlatformStand = true
		-- Maak BodyVelocity voor rustige fly omhoog, met MaxForce op alle assen voor stabiliteit
		if not flyBody or flyBody.Parent ~= hrp then
			flyBody = Instance.new("BodyVelocity")
			flyBody.Name = "FlyUpVelocity"
			flyBody.MaxForce = Vector3.new(math.huge, math.huge, math.huge)  -- Alle assen voor betere controle
			flyBody.Velocity = Vector3.new(0, flySpeed, 0)
			flyBody.Parent = hrp
		else
			flyBody.Velocity = Vector3.new(0, flySpeed, 0)
		end
	else
		-- Zet PlatformStand uit
		hum.PlatformStand = false
		if flyBody then
			flyBody:Destroy()
			flyBody = nil
		end
	end
end)

-- // MAIN LOOP
RunService.RenderStepped:Connect(function(dt)
	if not hrp or not hrp.Parent then return end

	-- Spin blijft zoals jij hem nice vond
	if spinning then
		hrp.CFrame = hrp.CFrame * CFrame.Angles(0, spinSpeed * dt, 0)
	end
end)
